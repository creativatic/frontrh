# Security & reproducibility settings for the HR system frontend.
# Mirrors ../sistema-rrhh-backend/.npmrc — same defenses.

# === SUPPLY-CHAIN HARDENING ===

# Block lifecycle scripts on ALL packages.
# Angular/PrimeNG don't need lifecycle scripts; this is safe.
# If a package needs to run something, do it manually.
ignore-scripts=true

# Force official registry.
registry=https://registry.npmjs.org/

# === REPRODUCIBILITY ===

save-exact=true
package-lock=true

# === AUDIT ===

audit-level=high

# === TLS ===

strict-ssl=true

# === ENGINE ===

engine-strict=true

# === COSMETIC ===

fund=false
